---
import { getEntry, render } from "astro:content";
import Doc from "../layouts/Doc.astro";
const entry = await getEntry("docs", "overview");
const { Content, headings } = await render(entry);
---
<Doc title={entry.data.title} description={entry.data.description} headings={headings} editPath={entry.data.editPath}>
  <Content />
</Doc>
