---
import { getCollection, render } from "astro:content";
import Doc from "../../../layouts/Doc.astro";
import ModuleGraph from "../../../components/ModuleGraph.astro";
import data from "../../../data/modules.json";

interface Dep { name: string; version: string; dev: boolean; in_registry: boolean; }
interface VDetail { version: string; integrity: string; url: string; }
interface Mod {
  name: string; latest: string; versions: number; versions_list: string[]; versions_detail: VDetail[];
  source: string; homepage: string; registry: string; category: string; description?: string;
  maintainers: { name: string; github?: string }[]; yanked: string[]; compatibility_level: number | null;
  deps: Dep[]; used_by: string[]; has_readme: boolean; docs: { slug: string; title: string }[];
}

export function getStaticPaths() {
  return (data.modules as Mod[]).map((mod) => ({ params: { name: mod.name }, props: { mod } }));
}
const { mod } = Astro.props as { mod: Mod };
const kind = mod.category === "Bazel rules" ? "Bazel ruleset" : "module";

// pull the fetched README + Stardoc docs from the moduledocs collection
const all = await getCollection("moduledocs");
const byId = new Map(all.map((e) => [e.id.replace(/\.md$/, ""), e]));
const readmeEntry = mod.has_readme ? byId.get(`${mod.name}/readme`) : undefined;
let ReadmeContent: any = null;
let readmeHeadings: { depth: number; slug: string; text: string }[] = [];
if (readmeEntry) { const r = await render(readmeEntry); ReadmeContent = r.Content; readmeHeadings = r.headings.filter((h) => h.depth === 2); }

const docRenders: { title: string; slug: string; Content: any }[] = [];
for (const d of mod.docs) {
  const e = byId.get(`${mod.name}/${d.slug}`);
  if (e) { const r = await render(e); docRenders.push({ title: d.title, slug: d.slug, Content: r.Content }); }
}

const hasDeps = mod.deps.length > 0 || mod.used_by.length > 0;
const headings = [
  ...readmeHeadings,
  ...(docRenders.length ? [{ depth: 2, slug: "rules", text: "Rules & providers" }] : []),
  ...(hasDeps ? [{ depth: 2, slug: "dependencies", text: "Dependencies" }] : []),
  { depth: 2, slug: "versions", text: "Versions" },
];
const crumbs = [
  { label: "Docs", href: "/" }, { label: "Reference" },
  { label: "Modules", href: "/reference/modules/" }, { label: mod.name },
];
const shortIntegrity = (s: string) => (s ? s.replace(/^sha256-/, "").slice(0, 16) + "…" : "");
const recent = [...mod.versions_detail].reverse();
---
<Doc
  title={mod.name}
  description={mod.description || `${mod.name} — a ${kind} in the tomato-bazel registry (latest ${mod.latest}).`}
  headings={headings}
  breadcrumbs={crumbs}
  editPath="../../tools/gen_modules.py"
>
  <p>{mod.description || `${mod.name} is a ${kind} published to the tomato-bazel registry.`}</p>

  <div class="tbl"><div class="tbl-scroll"><table><tbody>
    <tr><th>Latest</th><td><code>{mod.latest}</code></td></tr>
    <tr><th>Versions</th><td>{mod.versions}{mod.yanked.length > 0 && <span style="color:var(--muted)"> · {mod.yanked.length} yanked</span>}</td></tr>
    <tr><th>Category</th><td>{mod.category}</td></tr>
    {mod.compatibility_level != null && <tr><th>Compat level</th><td>{mod.compatibility_level}</td></tr>}
    {mod.maintainers.length > 0 && (
      <tr><th>Maintainers</th><td>{mod.maintainers.map((m, i) => (
        <>{i > 0 && ", "}{m.github ? <a class="link" href={`https://github.com/${m.github}`}>{m.name || m.github}</a> : m.name}</>
      ))}</td></tr>
    )}
    <tr><th>Registry</th><td><a class="link" href={mod.registry}>{mod.registry}</a></td></tr>
    {mod.source && <tr><th>Source</th><td><a class="link" href={mod.source}>{mod.source.replace("https://", "")}</a></td></tr>}
  </tbody></table></div></div>

  <div class="code">
    <button class="copy" type="button">Copy</button>
    <div class="cbar"><span class="fn">MODULE.bazel</span><span class="lang">starlark</span></div>
    <pre>bazel_dep(name = <span class="tok-s">"{mod.name}"</span>, version = <span class="tok-s">"{mod.latest}"</span>)</pre>
  </div>

  {mod.source && (
    <p><a class="ghlink" href={mod.source}>
      <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-.88-.01-1.73-2.78.62-3.37-1.37-3.37-1.37-.46-1.18-1.11-1.5-1.11-1.5-.9-.63.07-.62.07-.62 1 .07 1.53 1.05 1.53 1.05.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.36-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05a9.35 9.35 0 0 1 5 0c1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.35 4.8-4.58 5.06.36.32.68.94.68 1.9 0 1.37-.01 2.48-.01 2.82 0 .27.18.6.69.49A10.02 10.02 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z"/></svg>
      View source &amp; releases on GitHub ↗
    </a></p>
  )}

  {ReadmeContent ? <ReadmeContent /> : (
    <p style="color:var(--muted)">No README was published for this module. Its API, dependencies, and versions are below.</p>
  )}

  {docRenders.length > 0 && (
    <>
      <h2 id="rules">Rules &amp; providers<a class="anchor" href="#rules">#</a></h2>
      <p style="color:var(--muted)">Generated with <a class="link" href="https://github.com/bazelbuild/stardoc">Stardoc</a> from the module's <code class="ic">.bzl</code> sources.</p>
      {docRenders.map((d) => (
        <div class="stardoc"><h3 id={d.slug}>{d.title}</h3><d.Content /></div>
      ))}
    </>
  )}

  {hasDeps && (
    <>
      <h2 id="dependencies">Dependencies<a class="anchor" href="#dependencies">#</a></h2>
      <ModuleGraph name={mod.name} deps={mod.deps.map((d) => d.name)} usedBy={mod.used_by} />
      {mod.deps.length > 0 && (
        <>
          <h3>Depends on</h3>
          <div class="deprow">{mod.deps.map((d) => (
            d.in_registry
              ? <a class="depchip" href={`/reference/modules/${d.name}/`}>{d.name}<span class="dv">{d.version}</span>{d.dev && <span class="dtag">dev</span>}</a>
              : <span class="depchip ext">{d.name}<span class="dv">{d.version}</span>{d.dev && <span class="dtag">dev</span>}</span>
          ))}</div>
        </>
      )}
      {mod.used_by.length > 0 && (
        <>
          <h3>Used by <span style="color:var(--muted);font-weight:400">({mod.used_by.length} in the registry)</span></h3>
          <div class="deprow">{mod.used_by.map((u) => (
            <a class="depchip used" href={`/reference/modules/${u}/`}>{u}</a>
          ))}</div>
        </>
      )}
    </>
  )}

  <h2 id="versions">Versions<a class="anchor" href="#versions">#</a></h2>
  <p style="color:var(--muted)">{mod.versions} published version{mod.versions === 1 ? "" : "s"}, newest first. Each resolves to an immutable, integrity-checked archive.</p>
  <div class="tbl"><div class="tbl-scroll"><table>
    <thead><tr><th>Version</th><th>Integrity (sha256)</th><th>Source archive</th></tr></thead>
    <tbody>
      {recent.map((v, i) => (
        <tr>
          <td>
            <code style={mod.yanked.includes(v.version) ? "text-decoration:line-through;opacity:.6" : ""}>{v.version}</code>
            {i === 0 && <span class="badge b-stable" style="margin-left:8px">latest</span>}
            {mod.yanked.includes(v.version) && <span class="badge b-design" style="margin-left:8px">yanked</span>}
          </td>
          <td><code title={v.integrity} style="font-size:11.5px">{shortIntegrity(v.integrity) || "—"}</code></td>
          <td>{v.url ? <a class="link" href={v.url} style="font-size:12.5px">tag archive ↗</a> : "—"}</td>
        </tr>
      ))}
    </tbody>
  </table></div></div>

  <p style="margin-top:28px"><a class="link" href="/reference/modules/">← All modules</a></p>
</Doc>
